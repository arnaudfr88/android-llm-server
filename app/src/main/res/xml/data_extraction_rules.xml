<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup / data-extraction policy.

  This app stores large LLM model files (multiple GB) and device-specific
  request logs that are not useful to back up:
    - Models can always be re-downloaded from the recommended-models list.
    - Logs and settings are device-local and have no value off-device.

  Both cloud backups (Google Drive) and device-to-device transfers are
  fully disabled by including <exclude domain="root" /> in each section.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
